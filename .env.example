# Shopify custom app credentials (per ADR-0001: GraphQL Admin API only)
SHOPIFY_SHOP_DOMAIN=your-store.myshopify.com
SHOPIFY_API_VERSION=2026-04
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_ACCESS_TOKEN=
SHOPIFY_WEBHOOK_SECRET=

# ERPNext / Frappe REST API credentials
ERPNEXT_URL=https://erpnext.example.com
ERPNEXT_API_KEY=
ERPNEXT_API_SECRET=

# Single Shopify Location <-> ERPNext Warehouse pairing (per PRD)
SHOPIFY_LOCATION_GID=gid://shopify/Location/00000000
ERPNEXT_WAREHOUSE=Stores - TC

# Public base URL of the Connector's webhook-receiver endpoints
# (e.g. an ngrok/Cloudflare Tunnel URL in local development)
CONNECTOR_BASE_URL=https://your-tunnel.example.com

# Synced Entity / Retry Queue store
DATABASE_URL=sqlite:///./connector.db
